<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
  <mapper namespace="com.winter.jisu.notice.NoticeMapper">
  
  <insert id="happen" parameterType="NoticeDTO">
  INSERT INTO "TB_NOTICE" 
  		VALUES (DEFAULT,#{boardTitle}, #{boardWriter}, #{boardContents},now(), 0)
  </insert>
  
  <select id="yellow" resultType="NoticeDTO"> 
  INSERT INTO "TB_NOTICE"  
  </select>
  
    <select id="detail" resultType="NoticeDTO" parameterType="NoticeDTO"> 
  SELECT * from "TB_NOTICE" WHERE "BOARD_NUM"=#{boardNum}
  
  </select>
  
  
  </mapper>